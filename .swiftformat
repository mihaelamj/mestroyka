# SwiftFormat configuration. The mechanical formatting gate.
#
# Inert until Swift sources exist. The CI workflow that runs
# `swiftformat . --config .swiftformat --lint` plus build plus test ships with
# the engine package. Run `swiftformat . --config .swiftformat` before committing.

--swiftversion 6.1

# House style.
--indent 4
--maxwidth 180
--commas always

# Safe defaults that match the style above.
--trimwhitespace always
--semicolons never
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--self remove
